# Caddy: 자동 TLS(Let's Encrypt) + 리버스 프록시.
# 80/443이 열려 있어야 인증서 발급/리다이렉트가 동작한다.
# PSL 등재 도메인(예: *.duckdns.org)을 쓰면 LE rate limit 문제가 없다.
#
# 이 파일을 Caddyfile 로 복사하고 도메인을 채운 뒤 배포한다.
#   cp deploy/Caddyfile.example deploy/Caddyfile && sed -i 's/your-domain.example.com/<내도메인>/' deploy/Caddyfile

your-domain.example.com {
	reverse_proxy 127.0.0.1:8000
}
