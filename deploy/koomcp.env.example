# 배포 환경 고유값. 이 파일을 koomcp.env 로 복사한 뒤 실제 값으로 채운다.
#   cp deploy/koomcp.env.example deploy/koomcp.env
# 서버에선 /etc/koomcp.env 로 두고 systemd 유닛의 EnvironmentFile 이 읽는다.

# WorkOS AuthKit 도메인 (테넌트 고유)
AUTHKIT_DOMAIN=https://YOUR-TENANT.authkit.app

# 외부에 노출되는 베이스 URL (= 내 도메인)
BASE_URL=https://your-domain.example.com

# Caddy 사이트 주소 (보통 BASE_URL 의 호스트와 동일)
DOMAIN=your-domain.example.com
